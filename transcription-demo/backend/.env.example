# Hello — Hebrew voice transcription demo backend.
# Copy to `transcription-demo/backend/.env`. Full repo env catalog: see repo-root `.env.example`.

OPENAI_API_KEY=

# Optional. Chat model for cleanup after Whisper. Default in code: gpt-4o.
# OPENAI_CLEANUP_MODEL=gpt-4o

# Optional. HTTP port (default 4001).
# PORT=4001

# Optional. CORS allowed origin for the demo frontend (default http://localhost:3001).
# FRONTEND_ORIGIN=http://localhost:3001
