# Hello — thanks for opening the CRM Agent project.
#
# Where to copy:
#   • Repo root → `.env` for Express + tsx scripts (parser, eval, server).
#   • `client/` → see `client/.env.example` (Vite does not read the root `.env`).
#   • `transcription-demo/*` → see those folders’ `.env.example` files.

# =============================================================================
# OpenAI (used by: parser, transcription cleanup, eval judge, user-story runners)
# =============================================================================
OPENAI_API_KEY=

# Optional. Hebrew transcript cleanup model after Whisper. Default in code: gpt-5.
# OPENAI_CLEANUP_MODEL=gpt-5

# =============================================================================
# Main API server (`server/server.ts`)
# =============================================================================
# Optional. Listen port. Default: 3001.
# PORT=3001

# =============================================================================
# Web client — Vite (`client/`; copy vars into `client/.env` or `client/.env.local`)
# =============================================================================
# API origin, no trailing slash. Empty in production build = same origin. Dev fallback: http://localhost:3001.
# VITE_API_URL=http://localhost:3001

# =============================================================================
# Transcription demo backend (`transcription-demo/backend/`)
# =============================================================================
# OPENAI_API_KEY=          (same as above; listed again because this package uses its own `.env`)
# OPENAI_CLEANUP_MODEL=
# Optional. Default listen port: 4001.
# PORT=4001
# Optional. CORS origin for the demo SPA. Default: http://localhost:3001.
# FRONTEND_ORIGIN=http://localhost:3001

# =============================================================================
# Transcription demo frontend (`transcription-demo/frontend/`)
# =============================================================================
# Optional. Demo API URL. Default: http://localhost:4001.
# VITE_API_BASE=http://localhost:4001
