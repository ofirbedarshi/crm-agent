# Hello — this file is for the Vite web client only.
# Copy to `client/.env` or `client/.env.local`. The CRM API key lives in the repo-root `.env` (see root `.env.example`).

# API origin without trailing slash. In `npm run client:dev`, dev server defaults to http://localhost:3001 if unset.
# VITE_API_URL=http://localhost:3001

# Show the Hebrew message pipeline trace pane (third column). Omit or leave unset for default off.
# VITE_SHOW_MESSAGE_TRACE=true
