{
  "name": "crm-agent-parser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "eval:parser": "tsx src/parser/evalParser.ts",
    "eval:llm": "tsx src/eval/runEvaluation.ts",
    "eval:user-stories": "tsx src/userStories/runUserStoriesLive.ts",
    "demo": "tsx src/cli/demo.ts",
    "build": "npm install --prefix client --include=dev && npm run build --prefix client",
    "deploy:railway": "railway up",
    "start": "tsx server/server.ts",
    "server:dev": "tsx watch server/server.ts",
    "client:dev": "npm run dev --prefix client"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "openai": "^6.35.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
